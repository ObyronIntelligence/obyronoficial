# Variaveis do Obyron Neural

# Groq (Inference Rapida)
GROQ_API_KEY=sua-chave-groq-aqui
GROQ_MODEL=llama3-8b-8192

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
# Login com Google do site e configurado no painel do Supabase (Auth > Providers).

# Obsidian Local REST API
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=sua-chave-aqui

# Obsidian Vault Path
OBSIDIAN_VAULT_PATH=./obsidian

# Google APIs (automacoes)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=seu-refresh-token
GOOGLE_TIMEZONE=America/Sao_Paulo

# Google Calendar
GOOGLE_CALENDAR_ID=primary

# Google Sheets
GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_SHEET=Pagina1
GOOGLE_SHEETS_ALIASES={"gastos":"id-da-planilha","tarefas":"id-da-planilha"}
