# Variáveis do Obyron Neural

# Groq (Inference Rápida)
GROQ_API_KEY=sua-chave-groq-aqui
GROQ_MODEL=llama3-8b-8192

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJXXXXXXXXXXXXXXXXX

# Obsidian Local REST API
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=sua-chave-aqui

# Obsidian Vault Path
OBSIDIAN_VAULT_PATH=./obsidian

# Google OAuth
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REFRESH_TOKEN=seu-refresh-token
GOOGLE_TIMEZONE=America/Sao_Paulo

# Google Calendar
GOOGLE_CALENDAR_ID=primary

# Google Sheets
GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_SHEET=Pagina1
GOOGLE_SHEETS_ALIASES={"gastos":"id-da-planilha","tarefas":"id-da-planilha"}
